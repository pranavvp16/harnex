# Production env for the Azure VM. Copy to `.env` on the VM (NOT committed).
#
# Generation tips:
#   POSTGRES_PASSWORD / KEYCLOAK_DB_PASSWORD / KEYCLOAK_ADMIN_PASSWORD /
#   INFISICAL_AUTH_SECRET / INFISICAL_POSTGRES_PASSWORD / KEYCLOAK_ADMIN_CLIENT_SECRET:
#     LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 40
#   INFISICAL_ENCRYPTION_KEY (MUST be exactly 32 ASCII chars; raw bytes, not hex):
#     LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 32

# --- Public surface ---
# The Azure DNS label, region-suffixed. Caddy uses this for the Let's Encrypt cert
# and Keycloak uses it as the canonical hostname for OIDC.
HARNEX_PUBLIC_HOST=harnex-app.eastus2.cloudapp.azure.com

# --- Image source (Azure Container Registry) ---
ACR_LOGIN_SERVER=harnexacr.azurecr.io
IMAGE_TAG=latest

# --- App ---
HARNEX_ENV=prod
HARNEX_LOG_LEVEL=INFO

# --- Postgres (the api's DB) ---
POSTGRES_USER=harnex
POSTGRES_PASSWORD=
POSTGRES_DB=harnex

# --- Keycloak ---
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_REALM=harnex
KEYCLOAK_AUDIENCE=harnex-api
KEYCLOAK_JWKS_CACHE_SECONDS=300
# Filled by `infra/keycloak/post-import.sh` after first deploy. Leave blank initially.
KEYCLOAK_ADMIN_CLIENT_ID=harnex-admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Social IdP creds (optional). Configure GitHub/Google OAuth apps with callbacks at
# https://${HARNEX_PUBLIC_HOST}/auth/realms/harnex/broker/{github,google}/endpoint
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Infisical Cloud (third-party platform credentials only) ---
# Prod uses Infisical Cloud, not self-host. ENCRYPTION_KEY/AUTH_SECRET are
# self-host-only and intentionally omitted.
INFISICAL_BASE_URL=https://app.infisical.com
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# --- OpenAI embeddings ---
HARNEX_OPENAI_API_KEY=
HARNEX_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
HARNEX_OPENAI_EMBEDDING_DIM=1536

# --- Blaxel sandbox (code-mode execute path) ---
BLAXEL_API_KEY=
BLAXEL_BASE_URL=
BLAXEL_WORKSPACE_URL=
BLAXEL_WORKSPACE=
BLAXEL_SANDBOX_NAME=harnex-execute
BLAXEL_SANDBOX_IMAGE=blaxel/node:latest
BLAXEL_SANDBOX_REGION=us-pdx-1
BLAXEL_SANDBOX_MEMORY_MB=2048
BLAXEL_DEFAULT_TIMEOUT_SECONDS=30
BLAXEL_PYTHON_SANDBOX_NAME=harnex-execute-py
BLAXEL_PYTHON_SANDBOX_IMAGE=blaxel/py-app:latest
BLAXEL_SKIP_PYTHON_SYSTEM_PACKAGES=

# --- Billing (optional) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
