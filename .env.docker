# Docker test environment — all defaults filled in so you can run immediately.
# Usage: docker compose --env-file .env.docker up --build

# --- App ---
HARNEX_ENV=local
HARNEX_LOG_LEVEL=INFO
HARNEX_API_HOST=0.0.0.0
HARNEX_API_PORT=8000

# --- Postgres (host = postgres, not localhost, inside Docker) ---
DATABASE_URL=postgresql+asyncpg://harnex:harnex@postgres:5432/harnex
POSTGRES_USER=harnex
POSTGRES_PASSWORD=harnex
POSTGRES_DB=harnex

# --- Keycloak ---
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=harnex
KEYCLOAK_AUDIENCE=harnex-api
KEYCLOAK_JWKS_CACHE_SECONDS=300

KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080

# --- Infisical (self-hosted inside Docker) ---
INFISICAL_BASE_URL=http://localhost:8090
INFISICAL_INTERNAL_BASE_URL=http://infisical:8080
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

INFISICAL_ENCRYPTION_KEY=6c2f28e46e0f46b3a3f28e46e0f46b3a
INFISICAL_AUTH_SECRET=6c2f28e46e0f46b3a3f28e46e0f46b3a6c2f28e46e0f46b3a3f28e46e0f46b3a
INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=infisical
INFISICAL_POSTGRES_DB=infisical
INFISICAL_SITE_URL=http://localhost:8090

# --- Web build args ---
VITE_HARNEX_API_URL=http://localhost:8000
VITE_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/harnex
VITE_KEYCLOAK_CLIENT_ID=harnex-web
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_HARNEX_DEV_TENANT=11111111-1111-1111-1111-111111111111

# --- Azure (optional — leave empty to skip) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIM=1536

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_PREFIX=harnex

AZURE_STORAGE_CONNECTION_STRING=

# --- Blaxel (optional) ---
BLAXEL_BASE_URL=
BLAXEL_API_KEY=
BLAXEL_WORKSPACE_URL=
BLAXEL_WORKSPACE=
BLAXEL_SANDBOX_NAME=harnex-execute
BLAXEL_SANDBOX_IMAGE=blaxel/node:latest
BLAXEL_SANDBOX_REGION=us-pdx-1
BLAXEL_SANDBOX_MEMORY_MB=2048
BLAXEL_DEFAULT_TIMEOUT_SECONDS=30

# --- Billing (optional) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Fakes for local testing without Azure ---
HARNEX_USE_FAKE_EMBEDDINGS=1
HARNEX_USE_FAKE_VECTOR_SEARCH=1
