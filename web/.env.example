# Backend URL — optional in local Vite dev. If unset, the SPA uses same-origin
# `/v1/...` and `vite.config.ts` proxies to http://127.0.0.1:8000 (avoids CORS).
# Set this when the API is on a different host/port than the proxy default.
# VITE_HARNEX_API_URL=http://127.0.0.1:8000

# Dev-only tenant header (must match seeded `DEV_TENANT_ID` in the API).
VITE_HARNEX_DEV_TENANT=11111111-1111-1111-1111-111111111111

# Keycloak OIDC settings (single 'harnex' realm; tenant = organization/group)
VITE_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/harnex
VITE_KEYCLOAK_CLIENT_ID=harnex-web
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
