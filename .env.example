# Copy to `.env` for local overrides. `.env` is gitignored — do not commit secrets.
#
# DATABASE_URL is used for local (non-docker) runs only.
# Docker Compose builds its own DATABASE_URL from the POSTGRES_* vars below — no need to change it.

# --- App ---
HARNEX_ENV=local
HARNEX_LOG_LEVEL=INFO
HARNEX_API_HOST=0.0.0.0
HARNEX_API_PORT=8000

# Optional: Redis for shared rate limiting (unauthenticated POST /v1/tenants).
# Docker Compose sets HARNEX_REDIS_URL for the api service when unset. Leave empty for local
# uvicorn to use the in-memory fallback (dev-only; no coordination across workers).
# HARNEX_REDIS_URL=redis://localhost:6379/0

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://harnex:harnex@localhost:5432/harnex

# --- Docker Compose: databases & Keycloak ---
POSTGRES_USER=harnex
POSTGRES_PASSWORD=
POSTGRES_DB=harnex

KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Optional: overrides for api -> Keycloak / Infisical on the Docker network (defaults work)
# KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
# INFISICAL_INTERNAL_BASE_URL=http://infisical:8080

# --- Docker Compose: Infisical server ---
# INFISICAL_ENCRYPTION_KEY must be EXACTLY 32 characters (raw ASCII, not hex).
# AES-256 requires 32 bytes — a hex string would be 64 bytes and crashes KMS init.
# Generate: LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 32
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=
INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=
INFISICAL_POSTGRES_DB=infisical
INFISICAL_SITE_URL=http://localhost:8090

# --- Docker Compose: web SPA build ---
VITE_HARNEX_API_URL=http://localhost:8000
VITE_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/harnex
VITE_KEYCLOAK_CLIENT_ID=harnex-web
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/

# --- Keycloak (single 'harnex' realm; tenant = organization/group) ---
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=harnex
KEYCLOAK_AUDIENCE=harnex-api
KEYCLOAK_JWKS_CACHE_SECONDS=300

# Service-account client used by the API to create users (sign-up flow).
# Generate any opaque string; scripts/keycloak_setup.py will install it.
KEYCLOAK_ADMIN_CLIENT_ID=harnex-admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Social identity providers — leave blank to skip wiring during keycloak_setup.
# Google:  Cloud Console → OAuth 2.0 client → Authorized redirect URI
#          http://localhost:8080/realms/harnex/broker/google/endpoint
# GitHub:  Settings → Developer settings → OAuth Apps → callback URL
#          http://localhost:8080/realms/harnex/broker/github/endpoint
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Infisical (third-party platform credentials only) ---
INFISICAL_BASE_URL=http://localhost:8090
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# --- OpenAI embeddings (direct) ---
# Vectors live in Postgres via pgvector; OpenAI is only the embedding provider.
# Leave HARNEX_OPENAI_API_KEY empty to fall back to the deterministic fake provider
# (dev/test only — search relevance will be poor).
HARNEX_OPENAI_API_KEY=
HARNEX_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
HARNEX_OPENAI_EMBEDDING_DIM=1536

# --- Blaxel sandbox ---
BLAXEL_BASE_URL=
BLAXEL_API_KEY=
BLAXEL_WORKSPACE_URL=
BLAXEL_WORKSPACE=
BLAXEL_SANDBOX_NAME=harnex-execute
BLAXEL_SANDBOX_IMAGE=blaxel/node:latest
BLAXEL_SANDBOX_REGION=us-pdx-1
BLAXEL_SANDBOX_MEMORY_MB=2048
BLAXEL_DEFAULT_TIMEOUT_SECONDS=30
# Python sandbox (pdf / xlsx / pptx document skills — must match names used by uv run scripts/blaxel_provision.py)
BLAXEL_PYTHON_SANDBOX_NAME=harnex-execute-py
BLAXEL_PYTHON_SANDBOX_IMAGE=blaxel/py-app:latest
# Set to 1 to skip apt install of poppler-utils + libreoffice-calc inside blaxel_provision.py only
BLAXEL_SKIP_PYTHON_SYSTEM_PACKAGES=

# --- Billing ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Search/embedding test mode ---
# When set, bypass OpenAI and use deterministic fakes (tests only).
HARNEX_USE_FAKE_EMBEDDINGS=0
HARNEX_USE_FAKE_VECTOR_SEARCH=0
